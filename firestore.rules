rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && "email" in request.auth.token && request.auth.token.email in ["wwwrakibcom071@gmail.com", "arbnyt60@gmail.com"];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'name'])
        // id size check
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        // username check
        && data.username is string
        && data.username.size() >= 1
        && data.username.size() <= 100
        // name check
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 150
        // avatar check (optional)
        && (data.get('avatar', '') is string)
        && (data.get('avatar', '').size() <= 10485760)
        // bio check (optional)
        && (data.get('bio', '') is string)
        && (data.get('bio', '').size() <= 500)
        // theme check (optional)
        && (!('theme' in data) || data.theme in ['light', 'dark'])
        // verification checks
        && (!('isVerified' in data) || data.isVerified is bool)
        && (!('verificationStatus' in data) || data.verificationStatus in ['none', 'pending', 'accepted', 'rejected'])
        && (!('verificationData' in data) || data.verificationData is map)
        && (!('deactivated' in data) || data.deactivated is bool)
        && (!('hideBadges' in data) || data.hideBadges is bool)
        && (!('badges' in data) || data.badges is list)
        && (!('activeBadgeId' in data) || data.activeBadgeId is string || data.activeBadgeId == null)
        && (!('lastActive' in data) || data.lastActive is timestamp);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['id', 'userId', 'imageUrl', 'caption', 'likes', 'likedBy', 'createdAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        && data.userId is string
        && data.userId.size() >= 1
        && data.userId.size() <= 128
        && data.imageUrl is string
        && data.imageUrl.size() <= 10485760
        && data.caption is string
        && data.caption.size() <= 50000
        && data.likes is number
        && data.likedBy is list
        && data.likedBy.size() <= 10000
        && data.createdAt is timestamp;
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['id', 'followerId', 'followingId', 'createdAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        && data.followerId is string
        && data.followerId.size() >= 1
        && data.followingId is string
        && data.followingId.size() >= 1
        && data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'actorId', 'type', 'read', 'createdAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.userId is string
        && data.userId.size() >= 1
        && data.actorId is string
        && data.actorId.size() >= 1
        && data.type is string
        && data.type in ['like', 'comment', 'follow', 'system']
        && data.read is bool
        && data.createdAt is timestamp
        && (!('postId' in data) || (data.postId is string && data.postId.size() >= 1))
        && (!('message' in data) || (data.message is string && data.message.size() >= 1));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'users', 'lastMessage', 'updatedAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        && data.users is list
        && data.users.size() >= 2
        && data.users.size() <= 50
        && data.users[0] is string
        && data.users[1] is string
        && data.lastMessage is string
        && data.lastMessage.size() <= 5000
        && data.updatedAt is timestamp
        && (!('seenBy' in data) || (data.seenBy is list && data.seenBy.size() <= 50))
        && (!('isGroup' in data) || data.isGroup is bool)
        && (!('groupName' in data) || (data.groupName is string && data.groupName.size() <= 100))
        && (!('groupAvatar' in data) || (data.groupAvatar is string && data.groupAvatar.size() <= 10485760))
        && (!('admins' in data) || (data.admins is list && data.admins.size() <= 50))
        && (!('onlyAdminsCanAddMembers' in data) || data.onlyAdminsCanAddMembers is bool)
        && (!('theme' in data) || (data.theme is string && data.theme.size() <= 100))
        && (!('nicknames' in data) || data.nicknames is map);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'chatId', 'senderId', 'text', 'createdAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        && data.chatId is string
        && data.chatId.size() >= 1
        && data.senderId is string
        && data.senderId.size() >= 1
        && data.text is string
        && data.text.size() <= 5000
        && data.createdAt is timestamp
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 10485760) || data.imageUrl == null)
        && (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 10485760) || data.videoUrl == null)
        && (!('isDeleted' in data) || data.isDeleted is bool);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'postId', 'userId', 'text', 'createdAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        && data.postId is string
        && data.postId.size() >= 1
        && data.userId is string
        && data.userId.size() >= 1
        && data.text is string
        && data.text.size() >= 1
        && data.text.size() <= 1000
        && data.createdAt is timestamp;
    }

    function isValidStory(data) {
      return data.keys().hasAll(['id', 'userId', 'createdAt', 'expiresAt'])
        && data.id is string
        && data.id.size() >= 1
        && data.id.size() <= 128
        && data.userId is string
        && data.userId.size() >= 1
        && data.userId.size() <= 128
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 10485760))
        && (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 10485760))
        && (!('backgroundColor' in data) || (data.backgroundColor is string && data.backgroundColor.size() <= 100))
        && (!('textOverlays' in data) || data.textOverlays is list)
        && (!('imageOverlays' in data) || data.imageOverlays is list)
        && (!('poll' in data) || data.poll is map)
        && (!('song' in data) || data.song is map)
        && data.createdAt is timestamp
        && data.expiresAt is timestamp;
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().id == userId
                    && incoming().keys().hasAll(['id', 'username', 'name', 'avatar', 'bio'])
                    && incoming().keys().size() <= 6;

      allow update: if isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().id == existing().id // id cannot change
                    && (
                      (
                        isOwner(userId)
                        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'name', 'avatar', 'bio', 'theme', 'verificationStatus', 'verificationData', 'deactivated', 'hideBadges', 'activeBadgeId', 'lastActive'])
                        && (!('verificationStatus' in incoming().diff(existing()).affectedKeys()) || incoming().verificationStatus in ['pending', 'none'])
                      )
                      ||
                      (
                        isAdmin()
                        && incoming().diff(existing()).affectedKeys().hasOnly(['isVerified', 'verificationStatus', 'deactivated'])
                      )
                      ||
                      (
                        isSignedIn()
                        && incoming().diff(existing()).affectedKeys().hasOnly(['badges'])
                      )
                    );

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn()
                    && isOwner(incoming().userId)
                    && isValidId(storyId)
                    && isValidStory(incoming())
                    && incoming().id == storyId
                    && incoming().createdAt == request.time;
      allow delete: if isSignedIn()
                    && isOwner(existing().userId);

      match /likes/{likeId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && isValidId(likeId)
          && incoming().keys().hasAll(['id', 'userId', 'createdAt'])
          && incoming().id is string && incoming().id == likeId
          && incoming().userId is string && incoming().userId == request.auth.uid
          && incoming().createdAt is timestamp && incoming().createdAt == request.time;
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn()
          && isValidId(commentId)
          && incoming().keys().hasAll(['id', 'userId', 'text', 'createdAt'])
          && incoming().id is string && incoming().id == commentId
          && incoming().userId is string && incoming().userId == request.auth.uid
          && incoming().text is string && incoming().text.size() > 0 && incoming().text.size() <= 500
          && incoming().createdAt is timestamp && incoming().createdAt == request.time;
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
      
      match /pollVotes/{voteId} {
        allow read: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn()
          && isValidId(voteId)
          && incoming().keys().hasAll(['id', 'userId', 'optionIndex', 'createdAt'])
          && incoming().id is string && incoming().id == voteId
          && incoming().userId is string && incoming().userId == request.auth.uid
          && incoming().optionIndex is number
          && incoming().createdAt is timestamp && incoming().createdAt == request.time;
        allow update: if isSignedIn()
          && existing().userId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['optionIndex'])
          && incoming().optionIndex is number;
      }
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn()
                    && incoming().keys().hasAll(['id', 'reporterId', 'targetId', 'type', 'reason', 'status', 'createdAt'])
                    && incoming().id == reportId
                    && incoming().reporterId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn()
                    && isOwner(incoming().userId)
                    && isValidId(postId)
                    && isValidPost(incoming())
                    && incoming().id == postId
                    && incoming().createdAt == request.time
                    && incoming().likes == 0
                    && incoming().likedBy.size() == 0;

      allow update: if isSignedIn()
                    && isValidId(postId)
                    && isValidPost(incoming())
                    && incoming().id == existing().id
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().imageUrl == existing().imageUrl
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy']) ||
                      (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['caption'])) ||
                      (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['caption', 'likes', 'likedBy']))
                    );
      allow delete: if isSignedIn() && isOwner(existing().userId);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn()
                      && isOwner(incoming().userId)
                      && isValidId(commentId)
                      && isValidComment(incoming())
                      && incoming().id == commentId
                      && incoming().postId == postId
                      && incoming().createdAt == request.time;
        allow delete: if isSignedIn()
                      && isOwner(existing().userId);
      }
    }

    match /follows/{followId} {
      allow read: if isSignedIn() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid || true);
      allow list: if isSignedIn();
      allow create: if isSignedIn()
                    && isOwner(incoming().followerId)
                    && isValidId(followId)
                    && isValidFollow(incoming())
                    && incoming().id == followId
                    && incoming().createdAt == request.time;
      allow delete: if isSignedIn()
                    && isOwner(existing().followerId);
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn()
                    && isValidId(notificationId)
                    && isValidNotification(incoming())
                    && incoming().id == notificationId
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn()
                    && isOwner(existing().userId)
                    && isValidId(notificationId)
                    && isValidNotification(incoming())
                    && incoming().id == existing().id
                    && incoming().userId == existing().userId
                    && incoming().actorId == existing().actorId
                    && incoming().type == existing().type
                    && incoming().createdAt == existing().createdAt
                    && (!('postId' in incoming()) || incoming().postId == existing().postId)
                    && (!('postId' in existing()) || incoming().postId == existing().postId)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && (resource == null || request.auth.uid in resource.data.users);
      allow list: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn()
                    && request.auth.uid in incoming().users
                    && isValidId(chatId)
                    && isValidChat(incoming())
                    && incoming().id == chatId
                    && incoming().updatedAt == request.time;
      allow update: if isSignedIn()
                    && request.auth.uid in existing().users
                    && isValidId(chatId)
                    && isValidChat(incoming())
                    && incoming().id == existing().id
                    && (
                      (incoming().updatedAt == request.time && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'seenBy']))
                      ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['seenBy']))
                      ||
                      (
                        incoming().diff(existing()).affectedKeys().hasOnly(['users', 'groupAvatar', 'admins', 'onlyAdminsCanAddMembers', 'theme', 'nicknames', 'groupName'])
                        && (
                          !('users' in incoming().diff(existing()).affectedKeys())
                          || existing().get('onlyAdminsCanAddMembers', false) == false 
                          || request.auth.uid in existing().get('admins', [])
                        )
                      )
                    );
      allow delete: if isSignedIn() && request.auth.uid in existing().users;
      
      match /messages/{messageId} {
        allow read: if isSignedIn()
                     && exists(/databases/$(database)/documents/chats/$(chatId))
                     && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow list: if isSignedIn()
                     && exists(/databases/$(database)/documents/chats/$(chatId))
                     && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow create: if isSignedIn()
                      && isOwner(incoming().senderId)
                      && exists(/databases/$(database)/documents/chats/$(chatId))
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users
                      && isValidId(messageId)
                      && isValidMessage(incoming())
                      && incoming().id == messageId
                      && incoming().chatId == chatId
                      && incoming().createdAt == request.time;
        allow update: if isSignedIn()
                      && isOwner(existing().senderId)
                      && isValidId(messageId)
                      && isValidMessage(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['isDeleted', 'text', 'imageUrl', 'videoUrl'])
                      && incoming().isDeleted == true;
      }
    }

    match /contests/{contestId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && isValidId(contestId);
      allow update: if isSignedIn()
        && isValidId(contestId);
      allow delete: if isSignedIn() && isOwner(existing().hostId);
    }

    match /contest_matches/{matchId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && isValidId(matchId);
      allow update: if isSignedIn()
        && isValidId(matchId);
      allow delete: if isSignedIn();
    }
  }
}
